# Copy to .env locally or set these in your cloud host's secret manager.
# Do not commit real values.

OPENAI_API_KEY="replace-with-openai-platform-key"
OPENAI_MODEL="gpt-5.4-mini"

# This repo intentionally does not commit the real phone number.
BRIEF_TO_PHONE="+1REPLACE_ME"
BRIEFING_INTERVAL_HOURS="8"
BRIEFING_TIMEZONE="America/Los_Angeles"
BRIEFING_DRY_RUN="true"
BRIEFING_SEND_ON_START="false"
BRIEFING_ADMIN_TOKEN="replace-with-a-long-random-string"
HOLDINGS_PATH="config/holdings.local.json"

# Cloud worker option: set HOLDINGS_JSON to the full contents of config/holdings.local.json
# in the provider secret manager instead of mounting a private file.
# HOLDINGS_JSON='{"account_name":"taxable_robinhood","cash":0,"holdings":[]}'

# Twilio: use either TWILIO_FROM_PHONE or TWILIO_MESSAGING_SERVICE_SID.
TWILIO_ACCOUNT_SID="AC_REPLACE_ME"
TWILIO_AUTH_TOKEN="REPLACE_ME"
TWILIO_FROM_PHONE="+1REPLACE_ME"
# TWILIO_MESSAGING_SERVICE_SID="MG_REPLACE_ME"

# Comma-separated RSS feeds. Override if any feed gets flaky.
BRIEFING_NEWS_FEEDS="https://feeds.bbci.co.uk/news/business/rss.xml,https://finance.yahoo.com/news/rssindex,https://www.cnbc.com/id/100003114/device/rss/rss.html"
